# ============================================================
# Discourse Docker Community — Environment Configuration
# Copy to .env before first start:
#   cp .env.example .env
# Fill in every value marked with changeme_* before running.
# ============================================================

# -------------------------------------------------------
# Application
# -------------------------------------------------------

# Internal port the application listens on.
# Cloudflare Tunnel proxies traffic to http://10.0.1.204:APP_PORT
# NOTE: port 8090 chosen to avoid conflicts with other services on this host
# (pgadmin=8080, elearning=3000, strapi=1337, n8n=5678, portainer=9443)
APP_PORT=8090

# Public hostname used by Discourse (no https://, no trailing slash).
# Must match the domain configured in Cloudflare Tunnel.
DISCOURSE_HOSTNAME=community.example.com

# Site display name shown in the Discourse UI.
DISCOURSE_SITE_NAME=My Community

# Timezone (IANA format). Used inside all containers.
TIMEZONE=Europe/Madrid

# -------------------------------------------------------
# Admin account — used only during first-time bootstrap
# -------------------------------------------------------

# Initial admin username (lowercase, no spaces).
DISCOURSE_ADMIN_USERNAME=admin

# Initial admin email address.
DISCOURSE_ADMIN_EMAIL=admin@example.com

# Initial admin password — change immediately after first login.
DISCOURSE_ADMIN_PASSWORD=changeme_strong_admin_password

# Comma-separated list of email addresses with admin/developer access.
DISCOURSE_DEVELOPER_EMAILS=admin@example.com

# -------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------

POSTGRES_USER=discourse
POSTGRES_DB=discourse

# Strong random password — never commit this value.
# Suggested: openssl rand -base64 32
POSTGRES_PASSWORD=changeme_strong_db_password

# -------------------------------------------------------
# Redis
# -------------------------------------------------------

# Strong random password for the Redis instance.
# Suggested: openssl rand -base64 32
REDIS_PASSWORD=changeme_strong_redis_password

# -------------------------------------------------------
# SMTP — Brevo relay
# See docs/smtp-brevo.md for full setup instructions.
# -------------------------------------------------------

# Brevo SMTP relay host (do not change unless Brevo updates it).
DISCOURSE_SMTP_ADDRESS=smtp-relay.brevo.com

# SMTP port. 587 = STARTTLS (required by Brevo).
DISCOURSE_SMTP_PORT=587

# Your Brevo account login email.
DISCOURSE_SMTP_USER_NAME=your-brevo-login@example.com

# Brevo SMTP API key from: Brevo → Transactional → Email → SMTP & API → SMTP.
# This is NOT your Brevo account password.
DISCOURSE_SMTP_PASSWORD=your-brevo-smtp-api-key

# Enable STARTTLS. Required for port 587. Do not change.
DISCOURSE_SMTP_ENABLE_START_TLS=true
