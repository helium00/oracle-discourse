# ============================================================
# Discourse Docker Community — Environment Configuration
# cp .env.example .env   →   fill in values   →   make bootstrap
# ============================================================

# -------------------------------------------------------
# Network binding
# -------------------------------------------------------

# Internal port Discourse listens on (bound on all interfaces like other services).
# Cloudflare Tunnel proxies to http://<host>:APP_PORT
# Port 8090 avoids conflicts with: pgadmin=8080, elearning=3000,
# strapi=1337, n8n=5678, portainer=9443
APP_PORT=8090

# -------------------------------------------------------
# Application identity
# -------------------------------------------------------

# Public hostname (no https://, no trailing slash).
# Must match the domain configured in Cloudflare Tunnel.
DISCOURSE_HOSTNAME=community.example.com

# Site display name shown in the Discourse UI.
DISCOURSE_SITE_NAME=My Community

# -------------------------------------------------------
# Admin access
# -------------------------------------------------------

# Comma-separated emails that receive admin/developer access.
# First-time admin setup: register on the site with one of these emails.
DISCOURSE_DEVELOPER_EMAILS=admin@example.com

# -------------------------------------------------------
# discourse/discourse_docker installation directory
# -------------------------------------------------------

# Where the official launcher is installed (or will be cloned to).
DISCOURSE_DOCKER_DIR=/var/discourse

# -------------------------------------------------------
# SMTP — Brevo relay
# See docs/smtp-brevo.md for full setup instructions.
# -------------------------------------------------------

# Brevo SMTP relay host (do not change).
DISCOURSE_SMTP_ADDRESS=smtp-relay.brevo.com

# SMTP port. 587 = STARTTLS (required by Brevo).
DISCOURSE_SMTP_PORT=587

# Your Brevo account login email.
DISCOURSE_SMTP_USER_NAME=your-brevo-login@example.com

# Brevo SMTP API key from: Brevo → Transactional → Email → SMTP & API.
# This is NOT your Brevo account password.
DISCOURSE_SMTP_PASSWORD=your-brevo-smtp-api-key

# Sender address for notification emails (must be verified or on an authenticated
# domain in Brevo — Brevo → Senders & IP → Domains).
DISCOURSE_NOTIFICATION_EMAIL=noreply@noema-audioverse.com
